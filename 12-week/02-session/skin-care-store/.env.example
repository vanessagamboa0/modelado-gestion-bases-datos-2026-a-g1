# ===============================================
# ENVIRONMENT CONFIGURATION
# ===============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ===============================================
# APPLICATION
# ===============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Skin Care Store"

# ===============================================
# DATABASE
# ===============================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# Development (local)
DATABASE_URL="postgresql://postgres:password@localhost:5432/skincare_dev?schema=public"

# Production (Railway/Render)
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# ===============================================
# AUTHENTICATION (NextAuth.js)
# ===============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here-min-32-chars"
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional)
# Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub (optional for admin login)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ===============================================
# EMAIL SERVICE
# ===============================================
# Resend (recommended)
EMAIL_FROM="noreply@yourdomain.com"
RESEND_API_KEY=

# Alternative: SendGrid
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# ===============================================
# PAYMENT GATEWAY
# ===============================================
# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Alternative: MercadoPago (Phase 2)
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_PUBLIC_KEY=

# ===============================================
# FILE STORAGE
# ===============================================
# Vercel Blob (recommended for Vercel)
BLOB_READ_WRITE_TOKEN=

# Alternative: AWS S3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# Alternative: Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ===============================================
# ANALYTICS & MONITORING
# ===============================================
# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# ===============================================
# CACHE (Optional - Phase 2)
# ===============================================
# Redis
# REDIS_URL=redis://localhost:6379

# Upstash Redis (serverless)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ===============================================
# RATE LIMITING (Optional)
# ===============================================
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW=900000

# ===============================================
# SHIPPING (Optional - Phase 2)
# ===============================================
# ShipEngine
# SHIPENGINE_API_KEY=

# ===============================================
# FEATURE FLAGS
# ===============================================
NEXT_PUBLIC_ENABLE_WISHLIST=true
NEXT_PUBLIC_ENABLE_REVIEWS=true
NEXT_PUBLIC_ENABLE_COUPONS=true
NEXT_PUBLIC_ENABLE_GIFT_CARDS=false

# ===============================================
# DEVELOPMENT ONLY
# ===============================================
# Show detailed errors
SHOW_DETAILED_ERRORS=true

# Disable email sending in dev
DISABLE_EMAILS=false

# Mock payment gateway
MOCK_PAYMENTS=false

# Prisma Studio
# DATABASE_URL="postgresql://postgres:password@localhost:5432/skincare_dev?schema=public"
